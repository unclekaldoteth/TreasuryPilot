{
  "name": "treasurypilot",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node --env-file=.env.local --experimental-strip-types prisma/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@tetherto/wdk": "^1.0.0-beta.6",
    "@tetherto/wdk-protocol-bridge-usdt0-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-wallet": "^1.0.0-beta.7",
    "@tetherto/wdk-wallet-evm-erc-4337": "^1.0.0-beta.5",
    "next": "16.2.1",
    "prisma": "^6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "node --env-file=.env.local --experimental-strip-types prisma/seed.ts"
  }
}
